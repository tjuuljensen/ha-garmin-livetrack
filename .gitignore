.mypy_cache/
.ruff_cache/
.pyre/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment files
.env
.env.*
*.local

# IDE/editor
.vscode/
.idea/
*.code-workspace

# OS junk
.DS_Store
Thumbs.db
